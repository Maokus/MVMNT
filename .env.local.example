# Local development environment — overrides .env for `npm run dev`.
# Production and beta builds use .env.production / .env.beta regardless of this file.
#
# Get these values by running: supabase status  (after: supabase start)

VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY=<PUBLISHABLE_KEY from supabase status>
