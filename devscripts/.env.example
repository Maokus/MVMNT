# Deployment environment variables
#
# These are used by the deploy scripts in devscripts/. Copy this file to .env.deploy
# (which is git-ignored) and fill in your values, then source it before deploying:
#
#   source devscripts/.env.deploy
#   ./devscripts/deploy.sh

# Path to the Hugo profile site where MVMNT is deployed.
# The deploy script will try to auto-detect this via sibling layout (../../MISC/HugoProfileSite)
# but you can override it here if your layout is different.
# Example: /path/to/profile-site or ~/sites/my-profile
PROFILE_SITE_PATH=

# (Optional) Path to the MVMNT project itself.
# Usually not needed — the deploy script auto-detects it from its own location.
# Only set this if you have a non-standard layout.
# MVMNT_PATH=/path/to/mvmnt
